cat > .gitignore << 'EOF'
# Módulos e dependências do Node.js
node_modules/

# Arquivos de ambiente (.env - contém variáveis sensíveis)
.env
.env.local
.env.*.local

# Arquivos de log
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
logs/
log/

# Arquivos do sistema operacional
.DS_Store
.DS_Store?
._.DS_Store
**/.DS_Store
.DS_Store
Thumbs.db
ehthumbs.db

# Arquivos de IDE e editores
.vscode/
.idea/
*.code-workspace
.project
.buildpath
.settings/
*~
*.swp
*.swo

# Arquivos temporários
*.tmp
*.temp
temp/
tmp/

# Cache
.cache/
.npm/
.parcel-cache/

# Diretórios de build e distribuição
build/
dist/
.next/
.nuxt/
.svelte-kit/
.svelte/
coverage/
EOF